#!/bin/sh
set -e

echo "=== Nullroot OS Hardware Profiler ===" >&2

# 1. Probe CPU
CPU_VENDOR=$(grep -m1 "vendor_id" /proc/cpuinfo | awk '{print $3}' || echo "Unknown")
CPU_CORES=$(grep -c "^processor" /proc/cpuinfo || echo "1")
CPU_FLAGS=$(grep -m1 "^flags" /proc/cpuinfo | cut -d: -f2 | tr ' ' '\n' | grep -v '^$' | sort -u | xargs || echo "")

echo "Detected CPU: $CPU_VENDOR ($CPU_CORES cores)" >&2

# 2. Probe GPU
GPU_DRIVERS=""
GPU_INTEL="false"
GPU_AMD="false"
GPU_NVIDIA="false"
GPU_VIRTIO="false"

for card in /sys/class/drm/card[0-9]; do
  if [ -d "$card/device" ]; then
    VENDOR_FILE="$card/device/vendor"
    if [ -f "$VENDOR_FILE" ]; then
      VENDOR_ID=$(cat "$VENDOR_FILE" | tr -d ' ')
      case "$VENDOR_ID" in
        "0x8086")
          GPU_INTEL="true"
          GPU_DRIVERS="$GPU_DRIVERS i915"
          ;;
        "0x1002")
          GPU_AMD="true"
          GPU_DRIVERS="$GPU_DRIVERS amdgpu"
          ;;
        "0x10de")
          GPU_NVIDIA="true"
          GPU_DRIVERS="$GPU_DRIVERS nouveau"
          ;;
        "0x1af4")
          GPU_VIRTIO="true"
          GPU_DRIVERS="$GPU_DRIVERS virtio_gpu"
          ;;
      esac
    fi
  fi
done

# Strip whitespace
GPU_DRIVERS=$(echo "$GPU_DRIVERS" | xargs || echo "")
echo "Detected GPU drivers required: $GPU_DRIVERS" >&2

# 3. Probe Storage
STORAGE_DRIVERS=""
STORAGE_NVME="false"
STORAGE_AHCI="false"

if [ -d "/sys/class/nvme" ] || ls /sys/block/nvme* >/dev/null 2>&1; then
  STORAGE_NVME="true"
  STORAGE_DRIVERS="$STORAGE_DRIVERS nvme"
fi

# Probe AHCI / SATA controllers by PCI class
for class_file in /sys/bus/pci/devices/*/class; do
  if [ -f "$class_file" ]; then
    CLASS_ID=$(cat "$class_file" | cut -c1-6)
    if [ "$CLASS_ID" = "0x0106" ]; then
      STORAGE_AHCI="true"
      STORAGE_DRIVERS="$STORAGE_DRIVERS ahci libahci"
    fi
  fi
done

STORAGE_DRIVERS=$(echo "$STORAGE_DRIVERS" | xargs || echo "")
echo "Detected Storage drivers required: $STORAGE_DRIVERS" >&2

# 4. Probe Networking
NET_DRIVERS=""
NET_ETH="false"
NET_WIFI="false"

for net_dev in /sys/class/net/*; do
  DEV_NAME=$(basename "$net_dev")
  # Skip loopback
  if [ "$DEV_NAME" = "lo" ]; then
    continue
  fi
  
  # Check if it has a driver symlink
  if [ -d "$net_dev/device/driver" ]; then
    DRIVER_PATH=$(readlink "$net_dev/device/driver" || true)
    if [ -n "$DRIVER_PATH" ]; then
      DRIVER_NAME=$(basename "$DRIVER_PATH")
      NET_DRIVERS="$NET_DRIVERS $DRIVER_NAME"
      
      # Classify Ethernet vs Wi-Fi
      if [ -d "$net_dev/wireless" ] || [ -d "$net_dev/phy80211" ]; then
        NET_WIFI="true"
      else
        NET_ETH="true"
      fi
    fi
  fi
done

NET_DRIVERS=$(echo "$NET_DRIVERS" | xargs || echo "")
echo "Detected Network drivers required: $NET_DRIVERS" >&2

# Generate hardware.nix output structure
cat <<EOF
# Autogenerated by nullroot-detect on $(date)
{
  cpu = {
    vendor = "$CPU_VENDOR";
    cores = $CPU_CORES;
    flags = [ $(echo "$CPU_FLAGS" | sed 's/\([^ ]*\)/"\1"/g' | sed 's/ / /g') ];
  };

  gpu = {
    intel = $GPU_INTEL;
    amd = $GPU_AMD;
    nvidia = $GPU_NVIDIA;
    virtio = $GPU_VIRTIO;
    drivers = [ $(echo "$GPU_DRIVERS" | sed 's/\([^ ]*\)/"\1"/g' | sed 's/ / /g') ];
  };

  storage = {
    nvme = $STORAGE_NVME;
    ahci = $STORAGE_AHCI;
    drivers = [ $(echo "$STORAGE_DRIVERS" | sed 's/\([^ ]*\)/"\1"/g' | sed 's/ / /g') ];
  };

  networking = {
    ethernet = $NET_ETH;
    wifi = $NET_WIFI;
    drivers = [ $(echo "$NET_DRIVERS" | sed 's/\([^ ]*\)/"\1"/g' | sed 's/ / /g') ];
  };
}
EOF
